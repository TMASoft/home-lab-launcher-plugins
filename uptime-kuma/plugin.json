{
  "id": "uptime-kuma",
  "name": "Uptime Kuma",
  "version": "0.1.0",
  "launcherApiVersion": "1",
  "backend": "server/index.js",
  "frontend": "public/plugin.js",
  "permissions": ["routes", "storage", "jobs", "dashboard-section"],
  "configSchema": {
    "sectionTitle": { "type": "string", "default": "Uptime Kuma", "scope": "editor", "description": "Dashboard section title." },
    "url": { "type": "string", "default": "", "scope": "admin", "description": "The base URL of your Uptime Kuma instance (e.g., http://192.168.1.100:3001)." },
    "slug": { "type": "string", "default": "default", "scope": "editor", "description": "The slug of the Uptime Kuma status page." },
    "refreshMinutes": { "type": "number", "default": 2, "scope": "editor", "description": "Status refresh interval in minutes. Minimum 1." }
  }
}
